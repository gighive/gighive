# ------------------------------------------------------
# Security headers (requires mod_headers)
# ------------------------------------------------------
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "no-referrer-when-downgrade"
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
    {% if gighive_hsts_enabled | default(false) %}
    Header always set Strict-Transport-Security "{{ gighive_hsts_value | default('max-age=31536000; includeSubDomains; preload') }}"
    {% endif %}
</IfModule>

# Never serve cache/logs over HTTP
<Directory "/var/www/html/var/cache">
    Require all denied
</Directory>

<VirtualHost *:443>
    ServerName {{ gighive_fqdn | default(gighive_server_name) }}
    {% for alias in (gighive_server_aliases | default([gighive_server_alias] if (gighive_server_alias is defined) else [])) %}
    ServerAlias {{ alias }}
    {% endfor %}
    {% if (gighive_fqdn | default(gighive_server_name)) != gighive_host %}
    ServerAlias {{ gighive_host }}
    {% endif %}
    DocumentRoot /var/www/html
    DirectoryIndex index.php

    SSLEngine on
    SSLCertificateFile {{ gighive_ssl_cert_file | default('/etc/ssl/certs/origin_cert.pem') }}
    SSLCertificateKeyFile {{ gighive_ssl_key_file | default('/etc/ssl/private/origin_key.pem') }}
    SSLProtocol {{ gighive_ssl_protocols | default('all -SSLv3 -TLSv1 -TLSv1.1 +TLSv1.3') }}
    SSLCipherSuite {{ gighive_ssl_cipher_suite | default('HIGH:!aNULL:!MD5') }}
    SSLHonorCipherOrder {{ gighive_ssl_honor_order | default('on') }}
    Protocols {{ gighive_protocols | default('h2 http/1.1') }}

    ErrorLog ${APACHE_LOG_DIR}/error.log
    CustomLog ${APACHE_LOG_DIR}/access.log combined

    <IfModule mod_headers.c>
        Header always unset Cache-Control "expr=%{REQUEST_STATUS} == 401 || %{REQUEST_STATUS} == 404 || %{REQUEST_STATUS} == 500"
        Header always unset Pragma "expr=%{REQUEST_STATUS} == 401 || %{REQUEST_STATUS} == 404 || %{REQUEST_STATUS} == 500"
        Header always unset Expires "expr=%{REQUEST_STATUS} == 401 || %{REQUEST_STATUS} == 404 || %{REQUEST_STATUS} == 500"
        Header always set Cache-Control "no-store" "expr=%{REQUEST_STATUS} == 401 || %{REQUEST_STATUS} == 404 || %{REQUEST_STATUS} == 500"
        Header always set Pragma "no-cache" "expr=%{REQUEST_STATUS} == 401 || %{REQUEST_STATUS} == 404 || %{REQUEST_STATUS} == 500"
        Header always set Expires "0" "expr=%{REQUEST_STATUS} == 401 || %{REQUEST_STATUS} == 404 || %{REQUEST_STATUS} == 500"
    </IfModule>

    ErrorDocument 401 /errors/401.html
    ErrorDocument 404 /errors/404.html
    ErrorDocument 500 /errors/500.html

    # -------------------------------
    # API routing - Using MVC architecture in /src/
    # -------------------------------

    RewriteEngine On

    # Guest QR upload token detection — allows bypassing Basic Auth on token-authenticated paths.
    # Apache only uses this as a forward gate; PHP and tusd are the authoritative token validators.
    SetEnvIf X-Upload-Token .+ upload_token_auth
    # iOS AVPlayer sends X-Gallery-Nonce header via AVURLAsset HTTPHeaderFields
    SetEnvIf X-Gallery-Nonce .+ gallery_nonce_auth
    # Web browser <video src="/video/...?nonce=..."> — query-string detection
    SetEnvIf Request_URI "[?&]nonce=[A-Za-z0-9_\-]{30,40}" gallery_nonce_auth

    # QR guest upload routing — /upload/<token> served by PHP handler (rewritten internally)
    RewriteRule ^/upload/([A-Za-z0-9_-]+)$ /db/upload_form_single.php?token=$1 [L,QSA]

    # Route MVC API endpoints to the front controller.
    # Keep legacy script endpoint /api/uploads.php intact.
    RewriteCond %{REQUEST_URI} ^/api/uploads(?:/.*)?$
    RewriteCond %{REQUEST_URI} !^/api/uploads\.php$
    RewriteRule .* /src/index.php [QSA,L]

    RewriteCond %{REQUEST_URI} ^/api/media-files$
    RewriteRule .* /src/index.php [QSA,L]

    # -------------------------------
    # Root is public, but no indexes
    # -------------------------------
    <Directory "/var/www/html">
        AllowOverride None
        Options -Indexes +FollowSymLinks
        Require all granted
    </Directory>

    # ------------------------------------------------------
    # Protect non-root application paths with Basic Auth
    # ------------------------------------------------------
    # Deny cache outright (no auth challenge)
    <LocationMatch "^/app/cache(/|$)">
        Require all denied
    </LocationMatch>
    
    # --- PUBLIC HOMEPAGE ---
    # (No auth block here, so / and /index.php stay open)
    
    # Request-time staging-only public exception for /db/database.php
    <Location "/db/database.php">
        AuthMerging Off
        <If "%{HTTP_HOST} == 'staging.gighive.app'">
            Require all granted
        </If>
        <Else>
            AuthType Basic
            AuthName "GigHive Protected"
            AuthBasicProvider file
            AuthUserFile {{ gighive_htpasswd_path | default('/etc/apache2/gighive.htpasswd') }}
            Require valid-user
        </Else>
    </Location>

    # Request-time staging-only public exception for /api/tags.php
    <Location "/api/tags.php">
        AuthMerging Off
        <If "%{HTTP_HOST} == 'staging.gighive.app'">
            Require all granted
        </If>
        <Else>
            AuthType Basic
            AuthName "GigHive Protected"
            AuthBasicProvider file
            AuthUserFile {{ gighive_htpasswd_path | default('/etc/apache2/gighive.htpasswd') }}
            Require valid-user
        </Else>
    </Location>

    # Request-time staging-only public exception for /db/database_catalog.php
    <Location "/db/database_catalog.php">
        AuthMerging Off
        <If "%{HTTP_HOST} == 'staging.gighive.app'">
            Require all granted
        </If>
        <Else>
            AuthType Basic
            AuthName "GigHive Protected"
            AuthBasicProvider file
            AuthUserFile {{ gighive_htpasswd_path | default('/etc/apache2/gighive.htpasswd') }}
            Require valid-user
        </Else>
    </Location>

    # Request-time staging-only public access for /audio
    <LocationMatch "^/audio(?:/|$)">
        AuthMerging Off
        <If "%{HTTP_HOST} == 'staging.gighive.app'">
            Require all granted
        </If>
        <Else>
            AuthType Basic
            AuthName "GigHive Protected"
            AuthBasicProvider file
            AuthUserFile {{ gighive_htpasswd_path | default('/etc/apache2/gighive.htpasswd') }}
            Require valid-user
        </Else>
    </LocationMatch>

    # --- VIDEO DIRECTORY: Basic Auth for all roles; gallery nonce for approved guests ---
    # Apache is a forward gate only; nonce validity was established in guest-gallery.php
    # or guest_event_view.php before stream_url was issued. SHA-256 filenames provide a
    # second layer — unguessable without possessing the original file.
    # The staging conditional is preserved so staging.gighive.app retains its existing
    # public /video/ access; only non-staging environments use the RequireAny gate.
    <LocationMatch "^/video(?:/|$)">
        AuthMerging Off
        <If "%{HTTP_HOST} == 'staging.gighive.app'">
            Require all granted
        </If>
        <Else>
            AuthType Basic
            AuthName "GigHive Protected"
            AuthBasicProvider file
            AuthUserFile {{ gighive_htpasswd_path | default('/etc/apache2/gighive.htpasswd') }}
            <RequireAny>
                Require valid-user
                Require env gallery_nonce_auth
            </RequireAny>
        </Else>
    </LocationMatch>

    # --- EXISTING PROTECTED AREAS (any valid user) ---
    # Excludes /db/health.php from authentication requirement
    <LocationMatch "^/(?:app/(?!cache(?:/|$)).*|api|db/(?!health\.php$).*|debug|src|vendor|video(?!/podcasts(?:/|$))|audio)(?:/|$)">
        AuthType Basic
        AuthName "GigHive Protected"
        AuthBasicProvider file
        AuthUserFile {{ gighive_htpasswd_path | default('/etc/apache2/gighive.htpasswd') }}
        Require valid-user
    </LocationMatch>

    # --- UPLOAD FORMS: admin + uploader ---
    <Location "/db/upload_form.php">
        AuthType Basic
        AuthName "GigHive Upload"
        AuthUserFile {{ gighive_htpasswd_path | default('/etc/apache2/gighive.htpasswd') }}
        Require user admin uploader
    </Location>

    # --- ADMIN UPLOAD FORM: admin only ---
    <Location "/db/upload_form_admin.php">
        AuthType Basic
        AuthName "GigHive Admin"
        AuthUserFile {{ gighive_htpasswd_path | default('/etc/apache2/gighive.htpasswd') }}
        Require user admin
    </Location>


    <Location "/db/delete_media_files.php">
        AuthType Basic
        AuthName "GigHive Admin"
        AuthUserFile {{ gighive_htpasswd_path | default('/etc/apache2/gighive.htpasswd') }}
        Require user admin uploader
    </Location>

    # --- UPLOAD API: admin + uploader ---
    <Location "/api/uploads.php">
        AuthType Basic
        AuthName "GigHive Upload"
        AuthUserFile {{ gighive_htpasswd_path | default('/etc/apache2/gighive.htpasswd') }}
        Require user admin uploader
    </Location>

    # --- UPLOADS API (MVC ROUTES): admin + uploader, or QR upload token ---
    <LocationMatch "^/api/uploads(?:/|$)">
        AuthType Basic
        AuthName "GigHive Upload"
        AuthBasicProvider file
        AuthUserFile {{ gighive_htpasswd_path | default('/etc/apache2/gighive.htpasswd') }}
        <RequireAny>
            Require user admin uploader
            Require env upload_token_auth
        </RequireAny>
    </LocationMatch>

    # --- MEDIA-FILES API: admin + uploader ---
    <Location "/api/media-files">
        AuthType Basic
        AuthName "GigHive Upload"
        AuthUserFile {{ gighive_htpasswd_path | default('/etc/apache2/gighive.htpasswd') }}
        Require user admin uploader
    </Location>

    # --- TUS UPLOAD ENDPOINT: admin + uploader, or QR upload token ---
    <LocationMatch "^/files(?:/|$)">
        AuthType Basic
        AuthName "GigHive Upload"
        AuthBasicProvider file
        AuthUserFile {{ gighive_htpasswd_path | default('/etc/apache2/gighive.htpasswd') }}
        <RequireAny>
            Require user admin uploader
            Require env upload_token_auth
        </RequireAny>
    </LocationMatch>

    # --- QR GUEST LANDING PAGE: unauthenticated (Apache internally rewrites /upload/<token> here) ---
    # PHP gates admin features on $user === 'admin'; guests are gated by token validation.
    <Location "/db/upload_form_single.php">
        AuthMerging Off
        Require all granted
    </Location>

    # --- QR TOKEN VALIDATION API: unauthenticated by design; PHP validates the raw token ---
    <Location "/api/upload-token.php">
        AuthMerging Off
        Require all granted
    </Location>

    # --- GUEST GALLERY APIs: unauthenticated by design; PHP validates the nonce ---
    <Location "/api/guest-status.php">
        AuthMerging Off
        Require all granted
    </Location>

    <Location "/api/guest-gallery.php">
        AuthMerging Off
        Require all granted
    </Location>

    <Location "/api/guest-report.php">
        AuthMerging Off
        Require all granted
    </Location>

    <Location "/api/guest-stream.php">
        AuthMerging Off
        Require all granted
    </Location>

    <Location "/api/guest-delete.php">
        AuthMerging Off
        Require all granted
    </Location>

    ProxyPreserveHost On
    RequestHeader set X-Forwarded-Proto "https"
    ProxyPass "/files/" "http://{{ apache_container_name }}_tusd:8080{{ tusd_base_path | default('/files') }}/" nocanon
    ProxyPassReverse "/files/" "http://{{ apache_container_name }}_tusd:8080{{ tusd_base_path | default('/files') }}/"
    
    # --- ADMIN DIRECTORY: admin only ---
    # All admin UI pages and admin-only endpoints live under /admin/
    <Location "/admin/">
        AuthType Basic
        AuthName "GigHive Admin"
        AuthBasicProvider file
        AuthUserFile {{ gighive_htpasswd_path | default('/etc/apache2/gighive.htpasswd') }}
        LimitRequestBody {{ limit_request_body }}
        Require user admin
    </Location>

    # --- API DOCS: any valid user ---
    # Swagger UI and openapi.yaml contain admin endpoint paths; not for public access.
    <Location "/docs/">
        AuthType Basic
        AuthName "GigHive Protected"
        AuthBasicProvider file
        AuthUserFile {{ gighive_htpasswd_path | default('/etc/apache2/gighive.htpasswd') }}
        Require valid-user
    </Location>

    # ------------------------------------------------------
    # Extra safety: never serve these sensitive files
    # ------------------------------------------------------
 
     <IfModule mod_mime.c>
         AddType video/mp2t .m2t .ts
     </IfModule>
 
     <IfModule mod_headers.c>
         <FilesMatch "\.(m2t|ts)$">
             Header set Content-Disposition "attachment"
             Header set X-Content-Type-Options "nosniff"
         </FilesMatch>
     </IfModule>
 
    # --- APPLE-APP-SITE-ASSOCIATION: served publicly; Content-Type must be application/json ---
    # /.well-known/ is not in the catch-all auth LocationMatch, so no AuthMerging needed.
    <Location "/.well-known/apple-app-site-association">
        Header set Content-Type "application/json"
        Options -Indexes
    </Location>

    <FilesMatch "^(composer\.(json|lock)|config\.php)$">
        Require all denied
    </FilesMatch>

    # Also block hidden/dotfiles (e.g., .htpasswd, .env) just in case
    <FilesMatch "^\.">
        Require all denied
    </FilesMatch>
</VirtualHost>

{% if gighive_enable_telemetry_proxy | default(false) %}
<VirtualHost *:443>
    ServerName {{ gighive_telemetry_fqdn | default('telemetry.gighive.app') }}

    SSLEngine on
    SSLCertificateFile {{ gighive_ssl_cert_file | default('/etc/ssl/certs/origin_cert.pem') }}
    SSLCertificateKeyFile {{ gighive_ssl_key_file | default('/etc/ssl/private/origin_key.pem') }}
    SSLProtocol {{ gighive_ssl_protocols | default('all -SSLv3 -TLSv1 -TLSv1.1 +TLSv1.3') }}
    SSLCipherSuite {{ gighive_ssl_cipher_suite | default('HIGH:!aNULL:!MD5') }}
    SSLHonorCipherOrder {{ gighive_ssl_honor_order | default('on') }}
    Protocols {{ gighive_protocols | default('h2 http/1.1') }}

    ProxyPreserveHost On
    ProxyPass "/" "http://host.docker.internal:8088/"
    ProxyPassReverse "/" "http://host.docker.internal:8088/"
</VirtualHost>
{% endif %}
