SITE_URL=https://{{ ansible_host }}
DB_HOST={{ mysql_db_host }}
DB_PORT=3306

MYSQL_DATABASE={{ mysql_database | default('music_db') }}
MYSQL_USER={{ mysql_user | default('appuser') }}
MYSQL_PASSWORD={{ mysql_appuser_password | default('changeme_appuser') }}
# Optional: expose root password to containers/scripts if needed
MYSQL_ROOT_PASSWORD={{ mysql_root_password | default('changeme_root') }}

GIGHIVE_HTPASSWD_PATH={{ gighive_htpasswd_path }}
GIGHIVE_MYSQL_BACKUPS_DIR=/var/www/private/mysql_backups
GIGHIVE_MYSQL_RESTORE_LOG_DIR=/var/www/private/restorelogs
FILENAME_SEQ_PAD="${FILENAME_SEQ_PAD:-{{ filename_seq_pad }}}"

MEDIA_SEARCH_DIRS={{ media_search_dirs }}

MEDIA_LIST_PAGINATION_THRESHOLD={{ database_pagination_threshold | default(750) }}

APP_FLAVOR={{ app_flavor | default('gighive') }}
GIGHIVE_ENABLE_INSTALLATION_TRACKING={{ (gighive_enable_installation_tracking | default(true)) | ternary('true', 'false') }}
GIGHIVE_INSTALLATION_TRACKING_ENDPOINT={{ gighive_installation_tracking_endpoint | default('https://telemetry.gighive.app') }}
GIGHIVE_ENABLE_INSTALLATION_TRACKING_DEBUG={{ (gighive_enable_installation_tracking_debug | default(false)) | ternary('true', 'false') }}
GIGHIVE_INSTALL_CHANNEL={{ gighive_install_channel | default('full') }}
GIGHIVE_INSTALLATION_TRACKING_TIMEOUT_SECONDS={{ gighive_installation_tracking_timeout_seconds | default(3) }}

GA4_MEASUREMENT_ID_DEFAULTCODEBASE={{ ga4_measurement_id_defaultcodebase | default('G-MX1FQZ3H0W') }}
GA4_MEASUREMENT_ID_GIGHIVE={{ ga4_measurement_id_gighive | default('') }}

UPLOAD_ALLOWED_MIMES_JSON={{ gighive_upload_allowed_mimes | default([]) | to_json }}
UPLOAD_AUDIO_EXTS_JSON={{ gighive_upload_audio_exts | default([]) | to_json }}
UPLOAD_VIDEO_EXTS_JSON={{ gighive_upload_video_exts | default([]) | to_json }}

TUS_CLIENT_CHUNK_SIZE_BYTES={{ tus_client_chunk_size_bytes | default(8388608) }}
UPLOAD_MAX_BYTES={{ upload_max_bytes }}

GIGHIVE_FQDN={{ gighive_fqdn }}
GIGHIVE_INVENTORY_HOST=gighive_vm
GIGHIVE_INVENTORY_FILE=ansible/inventories/inventory_{{ hostname }}.yml

AI_WORKER_ENABLED={{ ai_worker_enabled | default(false) | ternary('true', 'false') }}
LLM_PROVIDER={{ llm_provider | default('openai') }}
OPENAI_API_KEY={{ openai_api_key | default('') }}
OPENAI_MODEL={{ openai_model | default('gpt-4.1') }}
LLM_BASE_URL={{ llm_base_url | default('https://api.openai.com/v1') }}
AI_FRAME_INTERVAL_SECONDS={{ ai_frame_interval_seconds | default(5) }}
AI_MAX_FRAMES_PER_JOB={{ ai_max_frames_per_job | default(48) }}
AI_MAX_FRAMES_PER_CHUNK={{ ai_max_frames_per_chunk | default(6) }}
AI_FRAME_RETENTION_DAYS={{ ai_frame_retention_days | default(30) }}
AI_WORKER_POLL_INTERVAL={{ ai_worker_poll_interval | default(5) }}
AI_WORKER_MAX_ATTEMPTS={{ ai_worker_max_attempts | default(3) }}
GIGHIVE_AI_ASSETS_ROOT={{ gighive_ai_assets_root | default('/data/ai_assets') }}
AI_MAX_TAGS_PER_ASSET={{ ai_max_tags_per_asset | default(25) }}
